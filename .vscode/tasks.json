{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🔍 Biome Check",
      "type": "shell",
      "command": "pnpm",
      "args": ["biome", "check", "."],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": [
        {
          "owner": "biome",
          "fileLocation": ["relative", "${workspaceFolder}"],
          "pattern": [
            {
              "regexp": "^(.*):(\\d+):(\\d+)\\s+(\\w+)\\/(\\w+)\\/(\\w+)\\s+(.*)$",
              "file": 1,
              "line": 2,
              "column": 3,
              "severity": 4,
              "code": 6,
              "message": 7
            }
          ]
        }
      ],
      "detail": "Verifica el código con Biome (linting + format) sin aplicar correcciones"
    },
    {
      "label": "🔧 Biome Fix",
      "type": "shell",
      "command": "pnpm",
      "args": ["biome", "check", "--write", "."],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": [
        {
          "owner": "biome",
          "fileLocation": ["relative", "${workspaceFolder}"],
          "pattern": [
            {
              "regexp": "^(.*):(\\d+):(\\d+)\\s+(\\w+)\\/(\\w+)\\/(\\w+)\\s+(.*)$",
              "file": 1,
              "line": 2,
              "column": 3,
              "severity": 4,
              "code": 6,
              "message": 7
            }
          ]
        }
      ],
      "detail": "Ejecuta Biome con corrección automática de errores y warnings"
    }
  ]
}
